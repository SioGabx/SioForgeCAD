      <MatchedAssemblyVersion>$([System.Text.RegularExpressions.Regex]::Match('$(AssemblyInfoContent)', '$(VersionRegex)'))</MatchedAssemblyVersion>
      <BuildAndRevision>$([System.Text.RegularExpressions.Regex]::Match('$(MatchedAssemblyVersion)', '$(BuildAndRevisionRegex)'))</BuildAndRevision>
      <BuildAndRevision>$(BuildAndRevision.Remove($(BuildAndRevision.LastIndexOf('"')), 1))</BuildAndRevision>
      <Build>$(BuildAndRevision.SubString(0, $(BuildAndRevision.LastIndexOf('.'))))</Build>
      <Revision>$(BuildAndRevision.SubString($([MSBuild]::Add($(BuildAndRevision.LastIndexOf('.')), 1))))</Revision>
      <Revision Condition="$([System.DateTime]::Now.Day) == $(Build)">$([MSBuild]::Add($(Revision), 1))</Revision>
      <Revision Condition="$([System.DateTime]::Now.Day) != $(Build)">1</Revision>
      <NewVersionValue>$([System.DateTime]::Now.ToString("yyyy.M.d.$(Revision)"))</NewVersionValue>
      <NewAssemblyVersion>[assembly: AssemblyVersion("$(NewVersionValue)")]</NewAssemblyVersion>
      <NewAssemblyFileVersion>[assembly: AssemblyFileVersion("$(NewVersionValue)")]</NewAssemblyFileVersion>
      <NewAssemblyInfoContent>$([System.Text.RegularExpressions.Regex]::Replace($(AssemblyInfoContent), $(VersionRegex), $(NewAssemblyVersion)))</NewAssemblyInfoContent>
      <NewAssemblyInfoContent>$([System.Text.RegularExpressions.Regex]::Replace($(NewAssemblyInfoContent), $(FileVersionRegex), $(NewAssemblyFileVersion)))</NewAssemblyInfoContent>
    </PropertyGroup>
    <WriteLinesToFile File="$(AssemblyInfo)" Lines="$(NewAssemblyInfoContent)" Overwrite="true" />
  </Target>
</Project>