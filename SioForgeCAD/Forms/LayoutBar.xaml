<UserControl x:Class="SioForgeCAD.Forms.LayoutBar"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:local="clr-namespace:SioForgeCAD.Forms"
             xmlns:theme="clr-namespace:Autodesk.Windows.Themes;assembly=AdUiPalettes" 
             mc:Ignorable="d"
             x:Name="LayoutBarRoot"
             Height="20"
             SnapsToDevicePixels="True"
             UseLayoutRounding="True">

    <UserControl.Resources>

        <SolidColorBrush x:Key="TabBarBackground" 
                 Color="{Binding Path=CurrentTheme.FileTabsRowBackgroundColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="TabInactiveBg" 
                 Color="{Binding Path=CurrentTheme.FileTabsInactiveBackgroundTopColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="TabHoverBg" 
                 Color="{Binding Path=CurrentTheme.FileTabsActiveBackgroundTopColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="TabBorder" 
                 Color="{Binding Path=CurrentTheme.FileTabsBorderColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="TextActive" 
                 Color="{Binding Path=CurrentTheme.ListBoxSelectTextColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="TextInactive" 
                 Color="{Binding Path=CurrentTheme.ListBoxInactiveTextColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="GroupHeaderBg" 
                 Color="{Binding Path=CurrentTheme.FileTabsInactiveBackgroundTopColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="GroupHeaderHoverBg" 
                 Color="{Binding Path=CurrentTheme.FileTabsActiveBackgroundTopColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="GroupHeaderActiveBg" 
                 Color="{Binding Path=CurrentTheme.FileTabsActiveBackgroundTopColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="NewBtnFg" 
                 Color="{Binding Path=CurrentTheme.FileTabsNewButtonForegroundColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="NewBtnHoverFg" 
                 Color="{Binding Path=CurrentTheme.FileTabsNewButtonForegroundHoverColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <SolidColorBrush x:Key="NewBtnPressedFg" 
                 Color="{Binding Path=CurrentTheme.FileTabsNewButtonForegroundClickColor, Source={x:Static theme:ThemeManager.PaletteSettings}}"/>

        <LinearGradientBrush x:Key="TabActiveBackground" EndPoint="0,1">
            <GradientStop Color="{Binding Path=CurrentTheme.FileTabsActiveBackgroundTopColor, Source={x:Static theme:ThemeManager.PaletteSettings}}" Offset="0"/>
            <GradientStop Color="{Binding Path=CurrentTheme.FileTabsActiveBackgroundBottomColor, Source={x:Static theme:ThemeManager.PaletteSettings}}" Offset="1"/>
        </LinearGradientBrush>
        
        <Geometry x:Key="TabEndFill">M 0,19 C 17,18 9,0 18,0.5 L 18,19</Geometry>
        <Geometry x:Key="TabEndStroke">M 0,18 L 0,18 C 17,18 9,0 18,0.5</Geometry>
        <Geometry x:Key="TabEndInnerStroke">M 0,17.5 C 18,18 10,1 18,0.5</Geometry>
        <Geometry x:Key="NewTabButtonShape">M 0,15 L 13,15 C 20,15 22,5 22,0 L 10,0 C 4,0 0,9 0,15 Z</Geometry>
        <Geometry x:Key="NewTabButtonPlusShape">M 0,0 L 2,0 2,3 5,3 5,5 2,5 2,8 0,8 0,5 -3,5 -3,3 0,3 Z</Geometry>
        <Geometry x:Key="LeftScrollButtonShape">M 0,0 L 25,0 35,20 0,20 Z</Geometry>
        <Geometry x:Key="RightScrollButtonShape">M 0,20 L 35,20 35,0 10,0 Z</Geometry>

        <BooleanToVisibilityConverter x:Key="BoolToVis"/>

        <Style x:Key="NewLayoutButtonStyle" TargetType="Button">
            <Setter Property="Width"  Value="22"/>
            <Setter Property="Height" Value="22"/>
            <Setter Property="Margin" Value="4,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="ToolTip" Value="Nouveau layout"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Grid>
                            <Path x:Name="BtnBg"
                                  Data="M 0,15 L 13,15 C 20,15 22,5 22,0 L 10,0 C 4,0 0,9 0,15 Z"
                                  Fill="{StaticResource TabInactiveBg}"
                                  Stroke="{StaticResource TabBorder}"
                                  StrokeThickness="0.5"
                                  Margin="0, 2,0,0"/>
                            <Path x:Name="Plus"
                                  Data="M 0,0 L 2,0 2,3 5,3 5,5 2,5 2,8 0,8 0,5 -3,5 -3,3 0,3 Z"
                                  Fill="{StaticResource NewBtnFg}"
                                  HorizontalAlignment="Center"
                                  VerticalAlignment="Center"
                                  Margin="3,-1,0,0"/>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Plus" Property="Fill" Value="{StaticResource NewBtnHoverFg}"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Plus"  Property="Fill"   Value="{StaticResource NewBtnPressedFg}"/>
                                <Setter TargetName="BtnBg" Property="Fill"   Value="{StaticResource TabActiveBackground}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="GroupHeaderButtonStyle" TargetType="Button">
            <Setter Property="Cursor"  Value="Hand"/>
            <Setter Property="Height"  Value="20"/>
            <Setter Property="Padding" Value="6,0,6,0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="HeaderBorder"
                                Background="{StaticResource GroupHeaderBg}"
                                BorderBrush="{StaticResource TabBorder}"
                                BorderThickness="0,0,1,0"
                                Padding="{TemplateBinding Padding}">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <TextBlock x:Name="ExpandIcon"
                                           Text="{Binding ExpandIcon}"
                                           Foreground="{StaticResource TextInactive}"
                                           FontSize="9"
                                           VerticalAlignment="Center"
                                           Margin="0,0,3,0"/>
                                <TextBlock x:Name="GroupTitle"
                                           Text="{Binding Title}"
                                           Foreground="{StaticResource TextInactive}"
                                           FontSize="11"
                                           FontWeight="SemiBold"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background"
                                        Value="{StaticResource GroupHeaderHoverBg}"/>
                                <Setter TargetName="GroupTitle" Property="Foreground"
                                        Value="{StaticResource TextActive}"/>
                                <Setter TargetName="ExpandIcon" Property="Foreground"
                                        Value="{StaticResource TextActive}"/>
                            </Trigger>
                            <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                <Setter TargetName="HeaderBorder" Property="Background"
                                        Value="{StaticResource GroupHeaderActiveBg}"/>
                                <Setter TargetName="GroupTitle" Property="Foreground"
                                        Value="{StaticResource TextActive}"/>
                                <Setter TargetName="ExpandIcon" Property="Foreground"
                                        Value="{StaticResource TextActive}"/>
                                <Setter TargetName="HeaderBorder" Property="BorderThickness"
                                        Value="1,0,1,0"/>
                            </DataTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="AcLayoutTabItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding"         Value="0"/>
            <Setter Property="Margin"          Value="-5,0,-20,0"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="IsSelected"      Value="{Binding IsCurrent, Mode=TwoWay}"/>
            <Setter Property="Panel.ZIndex"    Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Grid x:Name="TabRoot" VerticalAlignment="Stretch">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">

                                <Grid Margin="0" Width="19" VerticalAlignment="Bottom">
                                    <UIElement.RenderTransform>
                                        <TranslateTransform X="1"/>
                                    </UIElement.RenderTransform>
                                    <Path x:Name="LeftFill"
                                          Data="{StaticResource TabEndFill}"
                                          Fill="{StaticResource TabInactiveBg}">
                                        <UIElement.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleY="-1"/>
                                                <TranslateTransform Y="19"/>
                                            </TransformGroup>
                                        </UIElement.RenderTransform>
                                    </Path>
                                    <Path x:Name="LeftStroke"
                                          Data="{StaticResource TabEndStroke}"
                                          Stroke="{StaticResource TabBorder}"
                                          StrokeThickness="0.7">
                                        <UIElement.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleY="-1"/>
                                                <TranslateTransform Y="19"/>
                                            </TransformGroup>
                                        </UIElement.RenderTransform>
                                    </Path>
                                </Grid>

                                <Border x:Name="TabCenter"
                                        Background="{StaticResource TabInactiveBg}"
                                        MinWidth="20">
                                    <Border Padding="2,0" VerticalAlignment="Center">
                                        <TextBlock x:Name="TabLabel"
                                                   Text="{Binding Title}"
                                                   Foreground="{StaticResource TextInactive}"
                                                   FontSize="11"
                                                   VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxWidth="160"/>
                                    </Border>
                                </Border>

                                <Grid Margin="0" Width="24" Height="19" VerticalAlignment="Bottom">
                                    <UIElement.RenderTransform>
                                        <TransformGroup>
                                            <ScaleTransform ScaleX="-1" CenterX="9.5"/>
                                            <TranslateTransform X="-1"/>
                                        </TransformGroup>
                                    </UIElement.RenderTransform>
                                    <Path x:Name="RightFill"
                                          Data="{StaticResource TabEndFill}"
                                          Fill="{StaticResource TabInactiveBg}">
                                        <UIElement.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleY="-1"/>
                                                <TranslateTransform Y="19"/>
                                            </TransformGroup>
                                        </UIElement.RenderTransform>
                                    </Path>
                                    <Path x:Name="RightStroke"
                                          Data="{StaticResource TabEndStroke}"
                                          Stroke="{StaticResource TabBorder}"
                                          StrokeThickness="0.7">
                                        <UIElement.RenderTransform>
                                            <TransformGroup>
                                                <ScaleTransform ScaleY="-1"/>
                                                <TranslateTransform Y="19"/>
                                            </TransformGroup>
                                        </UIElement.RenderTransform>
                                    </Path>
                                </Grid>

                            </StackPanel>
                        </Grid>

                        <ControlTemplate.Triggers>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsSelected"    Value="False"/>
                                    <Condition Property="IsMouseOver"   Value="True"/>
                                </MultiTrigger.Conditions>
                                <Setter TargetName="LeftFill"   Property="Fill"       Value="{StaticResource TabHoverBg}"/>
                                <Setter TargetName="RightFill"  Property="Fill"       Value="{StaticResource TabHoverBg}"/>
                                <Setter TargetName="TabCenter"  Property="Background" Value="{StaticResource TabHoverBg}"/>
                                <Setter TargetName="TabLabel"   Property="Foreground" Value="{StaticResource TextActive}"/>
                            </MultiTrigger>

                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="LeftFill"   Property="Fill"       Value="{StaticResource TabActiveBackground}"/>
                                <Setter TargetName="RightFill"  Property="Fill"       Value="{StaticResource TabActiveBackground}"/>
                                <Setter TargetName="TabCenter"  Property="Background" Value="{StaticResource TabActiveBackground}"/>
                                <Setter TargetName="TabLabel"   Property="Foreground" Value="{StaticResource TextActive}"/>
                                <Setter TargetName="TabLabel"   Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="Panel.ZIndex" Value="2"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="GroupTemplate" DataType="{x:Type local:LayoutTabGroup}">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Stretch">
                <Button Style="{StaticResource GroupHeaderButtonStyle}"
                        Command="{Binding ToggleExpandCommand}"
                        ToolTip="{Binding Title}"/>

                <ItemsControl ItemsSource="{Binding Items}"
                              Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="VerticalAlignment" Value="Stretch"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:LayoutTabItem}">
                            <ListBoxItem Style="{StaticResource AcLayoutTabItemStyle}"
                                         MouseLeftButtonUp="TabItem_MouseLeftButtonUp"
                                         MouseRightButtonUp="TabItem_MouseRightButtonUp"
                                         VerticalContentAlignment="Stretch"
                                         VerticalAlignment="Stretch"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Width="1" Background="{StaticResource TabBorder}"
                        Margin="2,2,2,2"
                        Visibility="{Binding IsExpanded, Converter={StaticResource BoolToVis}}"/>
            </StackPanel>
        </DataTemplate>

    </UserControl.Resources>

    <Border Background="{StaticResource TabBarBackground}">
        <ScrollViewer HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      Focusable="False">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Stretch"
                        x:Name="MainPanel">

                <ItemsControl x:Name="FreeTabsControl"
                              VerticalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:LayoutTabItem}">
                            <ListBoxItem Style="{StaticResource AcLayoutTabItemStyle}"
                                         MouseLeftButtonUp="TabItem_MouseLeftButtonUp"
                                         MouseRightButtonUp="TabItem_MouseRightButtonUp"
                                         VerticalContentAlignment="Stretch"
                                         VerticalAlignment="Stretch"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ItemsControl x:Name="GroupsControl"
                              VerticalAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type local:LayoutTabGroup}">
                            <ContentPresenter Content="{Binding}"
                                              ContentTemplate="{StaticResource GroupTemplate}"
                                              VerticalAlignment="Stretch"/>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Button x:Name="NewLayoutBtn"
                        Style="{StaticResource NewLayoutButtonStyle}"
                        Click="NewLayoutBtn_Click"
                        VerticalAlignment="Center"/>

            </StackPanel>
        </ScrollViewer>
    </Border>
</UserControl>