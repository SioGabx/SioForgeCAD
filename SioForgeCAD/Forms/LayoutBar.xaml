<UserControl
    x:Class="SioForgeCAD.Forms.LayoutBar"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:SioForgeCAD.Forms"
    xmlns:theme="clr-namespace:Autodesk.Windows.Themes;assembly=AdUiPalettes"
    xmlns:ui="clr-namespace:SioForgeCAD.Commun.Mist.UI"
    x:Name="LayoutBarRoot"
    Height="28"
    SnapsToDevicePixels="True"
    UseLayoutRounding="True">

    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <ui:WidthToLeftMarginConverter x:Key="WidthToLeftMarginConverter" />
        <ui:LighteningConverter x:Key="LighteningConverter" />


        <SolidColorBrush x:Key="TabBarBackground" Color="{Binding Path=CurrentTheme.FileTabsRowBackgroundColor, Source={x:Static theme:ThemeManager.PaletteSettings}}" />

        <SolidColorBrush x:Key="TabInactiveBg" Color="{Binding Path=CurrentTheme.FileTabsInactiveBackgroundTopColor, Source={x:Static theme:ThemeManager.PaletteSettings}}" />
        <SolidColorBrush x:Key="TabHoverBg" Color="{Binding Path=CurrentTheme.FileTabsActiveBackgroundTopColor, Source={x:Static theme:ThemeManager.PaletteSettings}}" />
        <SolidColorBrush x:Key="TabBackground" Color="{Binding Path=CurrentTheme.FileTabsBorderColor, Source={x:Static theme:ThemeManager.PaletteSettings}}" />

        <SolidColorBrush x:Key="GroupTabBackground" Color="Transparent" />
        <SolidColorBrush x:Key="GroupTabHoverBackground" Color="#1AFFFFFF" />

        <SolidColorBrush x:Key="GroupSubTabInactiveBg">
            <SolidColorBrush.Color>
                <Binding
                    Converter="{StaticResource LighteningConverter}"
                    ConverterParameter="-0.4"
                    Path="Color"
                    Source="{StaticResource TabInactiveBg}" />
            </SolidColorBrush.Color>
        </SolidColorBrush>

        <SolidColorBrush x:Key="GroupSubTabHoverBg">
            <SolidColorBrush.Color>
                <Binding
                    Converter="{StaticResource LighteningConverter}"
                    ConverterParameter="-0.2"
                    Path="Color"
                    Source="{StaticResource TabHoverBg}" />
            </SolidColorBrush.Color>
        </SolidColorBrush>

        <SolidColorBrush x:Key="TextActive" Color="{Binding Path=CurrentTheme.ListBoxSelectTextColor, Source={x:Static theme:ThemeManager.PaletteSettings}}" />
        <SolidColorBrush x:Key="TextInactive" Color="{Binding Path=CurrentTheme.ListBoxInactiveTextColor, Source={x:Static theme:ThemeManager.PaletteSettings}}" />
        <SolidColorBrush x:Key="IconColors" Color="{Binding Path=CurrentTheme.ListBoxInactiveTextColor, Source={x:Static theme:ThemeManager.PaletteSettings}}" />



        <Style x:Key="TabItemContainerStyle" TargetType="ContentPresenter">
            <Setter Property="Margin" Value="0,0,0,0" />
            <Setter Property="AllowDrop" Value="True" />
            <Setter Property="Panel.ZIndex" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Panel.ZIndex" Value="50" />
                </Trigger>
                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter Property="Panel.ZIndex" Value="100" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="{x:Static MenuItem.SeparatorStyleKey}" TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="16,4,16,4" />
            <Setter Property="Background" Value="{StaticResource TabBackground}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border
                            Height="{TemplateBinding Height}"
                            Margin="{TemplateBinding Margin}"
                            Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="Separator">
            <Setter Property="Height" Value="1" />
            <Setter Property="Margin" Value="16,4,16,4" />
            <Setter Property="Background" Value="{StaticResource TabBackground}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Separator">
                        <Border
                            Height="{TemplateBinding Height}"
                            Margin="{TemplateBinding Margin}"
                            Background="{TemplateBinding Background}" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="MenuItem">
            <Setter Property="Foreground" Value="{StaticResource TextInactive}" />
            <Setter Property="Padding" Value="16,6,16,6" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="MenuItem">
                        <Border
                            x:Name="BgBorder"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            BorderThickness="2,0,0,0">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <ContentPresenter
                                    Margin="{TemplateBinding Padding}"
                                    ContentSource="Header"
                                    RecognizesAccessKey="True" />

                                <Path
                                    x:Name="RightArrow"
                                    Grid.Column="1"
                                    Margin="10,0,10,0"
                                    VerticalAlignment="Center"
                                    Data="M 0,0 L 4,4 L 0,8 Z"
                                    Fill="{StaticResource TextInactive}"
                                    Visibility="Collapsed" />

                                <Popup
                                    x:Name="PART_Popup"
                                    AllowsTransparency="True"
                                    Focusable="False"
                                    HorizontalOffset="-2"
                                    IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                    Placement="Right"
                                    PopupAnimation="Fade"
                                    VerticalOffset="-4">
                                    <Border
                                        Margin="0,0,8,8"
                                        Background="{StaticResource TabBarBackground}"
                                        BorderBrush="{StaticResource TabBackground}"
                                        BorderThickness="1"
                                        CornerRadius="4">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="6"
                                                Direction="270"
                                                Opacity="0.3"
                                                ShadowDepth="2" />
                                        </Border.Effect>
                                        <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Hidden">
                                            <ItemsPresenter Margin="0,4" />
                                        </ScrollViewer>
                                    </Border>
                                </Popup>
                            </Grid>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="HasItems" Value="True">
                                <Setter TargetName="RightArrow" Property="Visibility" Value="Visible" />
                            </Trigger>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource TabHoverBg}" />
                                <Setter Property="Foreground" Value="{StaticResource TextActive}" />
                                <Setter TargetName="BgBorder" Property="BorderBrush" Value="{StaticResource TextActive}" />
                                <Setter TargetName="RightArrow" Property="Fill" Value="{StaticResource TextActive}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Foreground" Value="#888888" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ContextMenu">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ContextMenu">
                        <Border
                            MinWidth="180"
                            Margin="0,0,8,8"
                            Background="{StaticResource TabBarBackground}"
                            BorderBrush="{StaticResource TabBackground}"
                            BorderThickness="1"
                            CornerRadius="4">
                            <Border.Effect>
                                <DropShadowEffect
                                    BlurRadius="8"
                                    Direction="270"
                                    Opacity="0.4"
                                    ShadowDepth="3" />
                            </Border.Effect>
                            <ItemsPresenter Margin="0,4" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <DataTemplate x:Key="TabTooltipTemplate">
            <Border
                Padding="6"
                Background="{StaticResource TabBarBackground}"
                BorderBrush="{StaticResource TabBackground}"
                BorderThickness="1">
                <TextBlock Foreground="{StaticResource TextActive}" Text="{Binding Title}" />
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:LayoutTab}">
            <Grid
                Height="28"
                Cursor="Hand"
                MouseLeftButtonDown="Item_MouseLeftButtonDown"
                MouseLeftButtonUp="Item_MouseLeftButtonUp">

                <Grid.ContextMenu>
                    <ContextMenu Opened="TabContextMenu_Opened">
                        <MenuItem
                            x:Name="TabMenuItem_Pin"
                            Click="ContextMenu_Epingler_Click"
                            Header="Épingler" />
                        <MenuItem
                            x:Name="TabMenuItem_Unpin"
                            Click="ContextMenu_Desepingler_Click"
                            Header="Désépingler" />
                        <Separator Margin="10,0" Background="{StaticResource TabBackground}" />

                        <MenuItem
                            x:Name="TabMenuItem_Rename"
                            Click="ContextMenu_Renommer_Click"
                            Header="Renommer" />
                        <MenuItem
                            x:Name="TabMenuItem_Trace"
                            Click="ContextMenu_Tracer_Click"
                            Header="Tracer" />
                        <MenuItem
                            x:Name="TabMenuItem_Publish"
                            Click="ContextMenu_Publier_Click"
                            Header="Publier" />
                        <MenuItem
                            x:Name="TabMenuItem_Delete"
                            Click="ContextMenu_Supprimer_Click"
                            Header="Supprimer" />
                        <Separator Margin="10,0" Background="{StaticResource TabBackground}" />
                        <MenuItem
                            x:Name="TabMenuItem_CreateGp"
                            Click="ContextMenu_CreerGroupe_Click"
                            Header="Créer un groupe avec la sélection" />
                    </ContextMenu>
                </Grid.ContextMenu>



                <Border
                    x:Name="TabBg"
                    Background="{StaticResource TabBarBackground}"
                    BorderBrush="{StaticResource TabBackground}"
                    BorderThickness="1,1,1,0">
                    <Border Background="{StaticResource TabInactiveBg}" />
                    <Border.RenderTransform>
                        <SkewTransform AngleX="-20" />
                    </Border.RenderTransform>
                </Border>
                <StackPanel
                    Margin="20,0,25,0"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,4,0"
                        FontSize="10"
                        Foreground="{StaticResource IconColors}"
                        Text="📌"
                        Visibility="{Binding IsPinned, Converter={StaticResource BooleanToVisibilityConverter}}" />
                    <TextBlock
                        x:Name="TabText"
                        FontSize="12"
                        Foreground="{StaticResource TextInactive}"
                        Text="{Binding Title}" />
                </StackPanel>

                <Grid.ToolTip>
                    <ToolTip
                        Content="{Binding}"
                        ContentTemplate="{StaticResource TabTooltipTemplate}"
                        Placement="Top"
                        VerticalOffset="-2" />
                </Grid.ToolTip>
            </Grid>
            <DataTemplate.Triggers>
                <DataTrigger Binding="{Binding IsInGroup}" Value="True">
                    <Setter TargetName="TabBg" Property="Background" Value="{StaticResource GroupSubTabInactiveBg}" />
                </DataTrigger>

                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="TabBg" Property="Background" Value="{StaticResource TabHoverBg}" />
                </Trigger>

                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding IsInGroup}" Value="True" />
                        <Condition Binding="{Binding RelativeSource={RelativeSource Mode=Self}, Path=IsMouseOver}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter TargetName="TabBg" Property="Background" Value="{StaticResource GroupSubTabHoverBg}" />
                </MultiDataTrigger>

                <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                    <Setter TargetName="TabBg" Property="Background" Value="{StaticResource TabHoverBg}" />
                    <Setter TargetName="TabText" Property="Foreground" Value="{StaticResource TextActive}" />
                    <Setter TargetName="TabText" Property="FontWeight" Value="Heavy" />
                </DataTrigger>

                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="TabBg" Property="Background" Value="{StaticResource TabHoverBg}" />
                    <Setter TargetName="TabText" Property="Foreground" Value="{StaticResource TextActive}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <DataTemplate DataType="{x:Type local:LayoutGroup}">
            <StackPanel Orientation="Horizontal">
                <Grid
                    Height="28"
                    Background="Transparent"
                    Cursor="Hand"
                    MouseLeftButtonDown="Item_MouseLeftButtonDown"
                    MouseLeftButtonUp="Item_MouseLeftButtonUp">

                    <Grid.ContextMenu>
                        <ContextMenu>
                            <MenuItem Click="ContextMenu_RenommerGroupe_Click" Header="Renommer le groupe" />
                            <MenuItem Click="ContextMenu_TracerGroupe_Click" Header="Tracer le groupe" />
                            <MenuItem Click="ContextMenu_PublierGroupe_Click" Header="Publier le groupe" />
                            <Separator Margin="10,0" Background="{StaticResource TabBackground}" />
                            <MenuItem Foreground="{StaticResource TextInactive}" Header="Supprimer...">
                                <MenuItem Click="ContextMenu_SupprimerGroupeSeul_Click" Header="Le groupe seulement" />
                                <MenuItem Click="ContextMenu_SupprimerGroupeEtContenu_Click" Header="Le groupe et son contenu" />
                            </MenuItem>
                        </ContextMenu>
                    </Grid.ContextMenu>

                    <Border
                        x:Name="GrpBg"
                        Background="{StaticResource TabBarBackground}"
                        BorderBrush="{StaticResource TabBackground}"
                        BorderThickness="1,1,1,0">
                        <Border Background="{StaticResource GroupTabBackground}" />
                        <Border.RenderTransform>
                            <SkewTransform AngleX="-20" />
                        </Border.RenderTransform>
                    </Border>
                    <StackPanel
                        Margin="20,0,25,0"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                        <TextBlock
                            x:Name="FolderIcon"
                            Margin="0,0,4,0"
                            FontSize="11"
                            Foreground="{StaticResource IconColors}"
                            Text="📁" />
                        <TextBlock
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="{StaticResource TextInactive}"
                            Text="{Binding Title}" />
                    </StackPanel>
                </Grid>

                <Grid Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">

                    <ItemsControl
                        x:Name="SubTabsControl"
                        ItemContainerStyle="{StaticResource TabItemContainerStyle}"
                        ItemsSource="{Binding SubTabs}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>

                    <Rectangle
                        Height="3"
                        Margin="-10,0,10,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Bottom"
                        Panel.ZIndex="5"
                        Fill="{StaticResource TabBarBackground}">
                        <Rectangle.RenderTransform>
                            <SkewTransform AngleX="-20" />
                        </Rectangle.RenderTransform>
                    </Rectangle>
                </Grid>

                <Rectangle
                    Width="3"
                    VerticalAlignment="Stretch"
                    Fill="{StaticResource TabBarBackground}"
                    Visibility="{Binding IsExpanded, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <Rectangle.RenderTransform>
                        <SkewTransform AngleX="-20" />
                    </Rectangle.RenderTransform>
                </Rectangle>



            </StackPanel>
            <DataTemplate.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter TargetName="GrpBg" Property="Background" Value="{StaticResource GroupTabHoverBackground}" />
                </Trigger>
                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                    <Setter TargetName="FolderIcon" Property="Text" Value="📂" />
                </DataTrigger>
                <DataTrigger Binding="{Binding IsSelected}" Value="True">
                    <Setter TargetName="GrpBg" Property="Background" Value="{StaticResource GroupTabHoverBackground}" />
                </DataTrigger>
            </DataTemplate.Triggers>
        </DataTemplate>

        <Geometry x:Key="OverflowChevron">M 0,0 L 4,4 8,0 M 0,5 L 4,9 8,5</Geometry>
        <Geometry x:Key="NewTabButtonPlusShape">M 0,0 L 2,0 2,3 5,3 5,5 2,5 2,8 0,8 0,5 -3,5 -3,3 0,3 Z</Geometry>
    </UserControl.Resources>

    <Border Background="{StaticResource TabBarBackground}">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Border x:Name="SpaceMeasure" Grid.Column="0" />

            <Grid
                Grid.Column="0"
                MaxWidth="{Binding ActualWidth, ElementName=SpaceMeasure}"
                HorizontalAlignment="Left">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ItemsControl
                    x:Name="PinnedControl"
                    Grid.Column="0"
                    Panel.ZIndex="4"
                    ItemContainerStyle="{StaticResource TabItemContainerStyle}"
                    ItemsSource="{Binding PinnedItems, ElementName=LayoutBarRoot}">

                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Background="Transparent" Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!--  PinnedTab right border  -->
                <Rectangle
                    Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Panel.ZIndex="5"
                    Fill="{StaticResource TabBarBackground}">
                    <Rectangle.RenderTransform>
                        <SkewTransform AngleX="-20" />
                    </Rectangle.RenderTransform>
                </Rectangle>

                <Rectangle
                    Grid.Column="0"
                    Width="3"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Stretch"
                    Panel.ZIndex="3"
                    Fill="{StaticResource TabBarBackground}">
                    <Rectangle.RenderTransform>
                        <SkewTransform AngleX="-20" />
                    </Rectangle.RenderTransform>
                </Rectangle>

                <ScrollViewer
                    x:Name="TabScrollViewer"
                    Grid.Column="0"
                    Grid.ColumnSpan="2"
                    Panel.ZIndex="1"
                    HorizontalScrollBarVisibility="Hidden"
                    PreviewMouseWheel="TabScrollViewer_PreviewMouseWheel"
                    VerticalScrollBarVisibility="Disabled">
                    <ItemsControl
                        x:Name="TabItemsControl"
                        Margin="{Binding ActualWidth, ElementName=PinnedControl, Converter={StaticResource WidthToLeftMarginConverter}}"
                        ItemContainerStyle="{StaticResource TabItemContainerStyle}"
                        ItemsSource="{Binding Items, ElementName=LayoutBarRoot}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Background="Transparent" Orientation="Horizontal" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                    </ItemsControl>
                </ScrollViewer>

                <Button
                    x:Name="AddBtn"
                    Grid.Column="2"
                    Width="24"
                    Height="24"
                    Margin="2,0"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="AddBtn_Click"
                    Cursor="Hand"
                    Foreground="{StaticResource TextInactive}">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Setter Property="Background" Value="Transparent" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource TabHoverBg}" />
                                    <Setter Property="Foreground" Value="{StaticResource TextActive}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>

                    <Path
                        HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Data="{StaticResource NewTabButtonPlusShape}"
                        Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                        StrokeThickness="0.5" />
                </Button>




            </Grid>

            <ToggleButton
                x:Name="OverflowToggle"
                Grid.Column="1"
                Width="24"
                Height="24"
                Margin="2,0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                Cursor="Hand"
                Foreground="{StaticResource TextInactive}">
                <ToggleButton.Style>
                    <Style TargetType="ToggleButton">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border Background="{TemplateBinding Background}" CornerRadius="3">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Background" Value="Transparent" />
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="{StaticResource TabHoverBg}" />
                                <Setter Property="Foreground" Value="{StaticResource TextActive}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter Property="Background" Value="{StaticResource TabHoverBg}" />
                                <Setter Property="Foreground" Value="{StaticResource TextActive}" />
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ToggleButton.Style>

                <Path
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Data="{StaticResource OverflowChevron}"
                    Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=ToggleButton}}"
                    StrokeThickness="1.5" />
            </ToggleButton>

            <Popup
                AllowsTransparency="True"
                IsOpen="{Binding IsChecked, ElementName=OverflowToggle}"
                Placement="Bottom"
                PlacementTarget="{Binding ElementName=OverflowToggle}"
                PopupAnimation="Fade"
                StaysOpen="False"
                VerticalOffset="0">

                <Border
                    MinWidth="180"
                    Margin="0,0,8,8"
                    Background="{StaticResource TabBarBackground}"
                    BorderBrush="{StaticResource TabBackground}"
                    BorderThickness="1"
                    CornerRadius="4">

                    <Border.Effect>
                        <DropShadowEffect
                            BlurRadius="8"
                            Direction="270"
                            Opacity="0.4"
                            ShadowDepth="3" />
                    </Border.Effect>

                    <ScrollViewer
                        MaxHeight="350"
                        HorizontalScrollBarVisibility="Disabled"
                        VerticalScrollBarVisibility="Hidden">

                        <Menu
                            Margin="0,4"
                            Background="Transparent"
                            ItemsSource="{Binding Items, ElementName=LayoutBarRoot}">
                            <Menu.Resources>
                                <Style TargetType="MenuItem">
                                    <Setter Property="Header" Value="{Binding Title}" />
                                    <Setter Property="ItemsSource" Value="{Binding SubTabs}" />
                                    <Setter Property="Foreground" Value="{StaticResource TextInactive}" />
                                    <Setter Property="Padding" Value="16,6,16,6" />
                                    <Setter Property="Cursor" Value="Hand" />
                                    <EventSetter Event="Click" Handler="OverflowMenuItem_Click" />

                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="MenuItem">
                                                <Border
                                                    x:Name="BgBorder"
                                                    Background="Transparent"
                                                    BorderBrush="Transparent"
                                                    BorderThickness="2,0,0,0">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>

                                                        <ContentPresenter
                                                            Margin="{TemplateBinding Padding}"
                                                            ContentSource="Header"
                                                            RecognizesAccessKey="True" />

                                                        <Path
                                                            x:Name="RightArrow"
                                                            Grid.Column="1"
                                                            Margin="10,0,10,0"
                                                            VerticalAlignment="Center"
                                                            Data="M 0,0 L 4,4 L 0,8 Z"
                                                            Fill="{StaticResource TextInactive}"
                                                            Visibility="Collapsed" />

                                                        <Popup
                                                            x:Name="PART_Popup"
                                                            AllowsTransparency="True"
                                                            Focusable="False"
                                                            HorizontalOffset="-2"
                                                            IsOpen="{Binding IsSubmenuOpen, RelativeSource={RelativeSource TemplatedParent}}"
                                                            Placement="Right"
                                                            PopupAnimation="Fade"
                                                            VerticalOffset="-4">
                                                            <Border
                                                                Margin="0,0,8,8"
                                                                Background="{StaticResource TabBarBackground}"
                                                                BorderBrush="{StaticResource TabBackground}"
                                                                BorderThickness="1"
                                                                CornerRadius="4">
                                                                <Border.Effect>
                                                                    <DropShadowEffect
                                                                        BlurRadius="6"
                                                                        Direction="270"
                                                                        Opacity="0.3"
                                                                        ShadowDepth="2" />
                                                                </Border.Effect>
                                                                <ScrollViewer MaxHeight="300" VerticalScrollBarVisibility="Hidden">
                                                                    <ItemsPresenter Margin="0,4" />
                                                                </ScrollViewer>
                                                            </Border>
                                                        </Popup>
                                                    </Grid>
                                                </Border>

                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="HasItems" Value="True">
                                                        <Setter TargetName="RightArrow" Property="Visibility" Value="Visible" />
                                                    </Trigger>

                                                    <Trigger Property="IsHighlighted" Value="True">
                                                        <Setter TargetName="BgBorder" Property="Background" Value="{StaticResource TabHoverBg}" />
                                                        <Setter Property="Foreground" Value="{StaticResource TextActive}" />
                                                        <Setter TargetName="RightArrow" Property="Fill" Value="{StaticResource TextActive}" />
                                                    </Trigger>

                                                    <DataTrigger Binding="{Binding IsCurrent}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextActive}" />
                                                        <Setter Property="FontWeight" Value="SemiBold" />
                                                        <Setter TargetName="BgBorder" Property="BorderBrush" Value="{StaticResource TextActive}" />
                                                    </DataTrigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </Menu.Resources>

                            <Menu.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <VirtualizingStackPanel Orientation="Vertical" />
                                </ItemsPanelTemplate>
                            </Menu.ItemsPanel>
                        </Menu>
                    </ScrollViewer>
                </Border>
            </Popup>

            <Popup
                x:Name="DragIndicator"
                AllowsTransparency="True"
                IsHitTestVisible="False">
                <Path
                    Margin="0,0,0,0"
                    Data="M 0,0 L 10,0 L 5,8 Z"
                    Fill="#608fbf" />
            </Popup>
        </Grid>
    </Border>
</UserControl>